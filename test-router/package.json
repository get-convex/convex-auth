{
  "name": "test-example",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "npm-run-all --parallel dev:frontend dev:backend",
    "dev:frontend": "vite --open --port 3000",
    "dev:backend": "convex dev",
    "predev": "convex dev --until-success && convex dashboard",
    "build": "tsc && vite build",
    "lint": "tsc && tsc -p convex/tsconfig.json && eslint . --report-unused-disable-directives --max-warnings 0",
    "preview": "vite preview",
    "test": "vitest",
    "test:once": "vitest run",
    "test:debug": "vitest --inspect-brk --no-file-parallelism",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@convex-dev/auth": "file:..",
    "@oslojs/crypto": "^1.0.1",
    "@radix-ui/react-dialog": "^1.0.5",
    "@radix-ui/react-dropdown-menu": "^2.0.6",
    "@radix-ui/react-icons": "^1.3.0",
    "@radix-ui/react-slot": "^1.0.2",
    "@radix-ui/react-tabs": "^1.1.0",
    "@radix-ui/react-toast": "^1.2.1",
    "@radix-ui/react-toggle": "^1.0.3",
    "@radix-ui/react-toggle-group": "^1.0.4",
    "@react-email/components": "^0.5.0",
    "@tanstack/react-router": "^1.40.0",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "convex": "file:../node_modules/convex",
    "input-otp": "^1.2.4",
    "next-themes": "^0.4.0",
    "react": "file:../node_modules/react",
    "react-dom": "file:../node_modules/react-dom",
    "resend": "^3.2.0",
    "tailwind-merge": "^2.3.0",
    "tailwindcss-animate": "^1.0.7",
    "twilio": "^5.2.0"
  },
  "devDependencies": {
    "@edge-runtime/vm": "5.0.0",
    "@tanstack/router-devtools": "1.130.2",
    "@tanstack/router-plugin": "1.130.2",
    "@types/node": "20.19.9",
    "@types/react": "18.3.23",
    "@types/react-dom": "18.3.7",
    "@typescript-eslint/eslint-plugin": "7.18.0",
    "@typescript-eslint/parser": "7.18.0",
    "@vitejs/plugin-react": "4.7.0",
    "@vitest/coverage-v8": "1.6.1",
    "autoprefixer": "10.4.21",
    "cheerio": "1.1.0",
    "convex-test": "0.0.21",
    "eslint": "8.57.1",
    "eslint-plugin-no-only-tests": "3.3.0",
    "eslint-plugin-react-hooks": "4.6.2",
    "eslint-plugin-react-refresh": "0.4.20",
    "jsdom": "29.0.2",
    "postcss": "8.5.6",
    "prettier": "3.8.3",
    "tailwindcss": "3.4.17",
    "typescript": "5.8.3",
    "vite": "5.4.21",
    "vitest": "1.6.1"
  }
}
